<UserControl
    x:Class="Bot.AssistWindow.Widget.RightPanel" 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Bot.AssistWindow.Widget"
    Background="#FFFFFFFF">
    <UserControl.Resources>
        <SolidColorBrush Color="#2F80ED" x:Key="rpPrimaryBlueBrush" />
        <SolidColorBrush Color="#246BCE" x:Key="rpPrimaryBlueHoverBrush" />
        <SolidColorBrush Color="#FFFFFF" x:Key="rpWhiteBrush" />
        <SolidColorBrush Color="#E6ECF2" x:Key="rpBorderBrush" />
        <SolidColorBrush Color="#F7F9FC" x:Key="rpPageBgBrush" />
        <Style TargetType="{x:Type Button}" x:Key="TopBarButton">
            <Setter Property="Foreground" Value="#FFFFFFFF" />
            <Setter Property="Background" Value="#00FFFFFF" />
            <Setter Property="BorderBrush" Value="#55FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="9 4" />
            <Setter Property="Margin" Value="4 5" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
        <Style TargetType="{x:Type TabItem}" x:Key="tabRightPanel">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border Name="Border" Margin="0" Padding="10 5" Background="#FFFFFFFF" BorderBrush="{StaticResource rpBorderBrush}" BorderThickness="0 0 1 1">
                            <ContentPresenter Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="TabItem.IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#EAF5FF" />
                                <Setter Property="Foreground" Value="#2F80ED" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Border Grid.RowSpan="2" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="#FFFFFFFF" BorderBrush="{StaticResource rpBorderBrush}" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="0" Opacity="0.18" />
            </Border.Effect>
        </Border>

        <Grid Grid.Row="0" Background="{StaticResource rpPrimaryBlueBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="10 0 0 0">
                <Image Source="{StaticResource iconYellow}" Width="18" Height="18" Margin="0 0 6 0" />
                <TextBlock Text="AI客服控制台" Foreground="#FFFFFFFF" FontSize="17" FontWeight="Bold" VerticalAlignment="Center" />
            </StackPanel>
            <CheckBox Name="cboxPanelBotEnabled" Grid.Column="1" Margin="8 0 4 0" VerticalAlignment="Center" Foreground="#FFFFFFFF" FontWeight="SemiBold" Click="cboxPanelBotEnabled_Click">启用Bot</CheckBox>
            <CheckBox Name="cboxPanelAuto" Grid.Column="2" Margin="6 0 4 0" VerticalAlignment="Center" Foreground="#FFFFFFFF" FontWeight="SemiBold" Click="cboxPanelAuto_Click">自动回复</CheckBox>
            <Button Name="btnOption" Grid.Column="3" Style="{StaticResource TopBarButton}" Content="设置" Click="btnOption_Click">
                <Button.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="工作台" Click="menuWorkbench_Click" />
                        <MenuItem Header="API接口" Click="menuApi_Click" />
                        <MenuItem Header="知识库" Tag="知识库" Click="menuFeatureSettings_Click" />
                        <MenuItem Header="自动回复规则" Tag="自动回复规则" Click="menuFeatureSettings_Click" />
                        <MenuItem Header="消息策略" Tag="消息策略" Click="menuFeatureSettings_Click" />
                        <Separator />
                        <MenuItem Header="数据统计" Click="menuWorkbench_Click" />
                        <MenuItem Header="日志与调试" Tag="日志与调试" Click="menuFeatureSettings_Click" />
                        <MenuItem Header="配置导入/导出" Click="menuApi_Click" />
                        <MenuItem Header="账号与授权" Tag="账号与授权" Click="menuFeatureSettings_Click" />
                        <MenuItem Header="商业化合规清单" Tag="商业化合规清单" Click="menuFeatureSettings_Click" />
                        <Separator />
                        <MenuItem Header="帮助" Click="menuHelp_Click" />
                        <MenuItem Header="关于" Click="menuAbout_Click" />
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
            <Button Name="btnSyn" Grid.Column="4" Style="{StaticResource TopBarButton}" Click="btnHide_Click">隐藏</Button>
        </Grid>

        <TabControl Name="tabControl" Grid.Row="1" Background="{StaticResource rpPageBgBrush}" BorderThickness="0" />

        <Rectangle Grid.RowSpan="2" HorizontalAlignment="Right" VerticalAlignment="Stretch" Width="5" Cursor="SizeWE" Fill="#00FFFFFF" MouseLeftButtonDown="rectWiden_MouseLeftButtonDown" MouseLeftButtonUp="rectWiden_MouseLeftButtonUp" MouseMove="rectWiden_MouseMove" />
        <Rectangle Grid.Row="1" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Height="5" Cursor="SizeNS" Fill="#00FFFFFF" MouseLeftButtonDown="rectHighden_MouseLeftButtonDown" MouseLeftButtonUp="rectHighden_MouseLeftButtonUp" MouseMove="rectHighden_MouseMove" />
        <Rectangle Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom" Height="5" Width="5" Cursor="SizeNWSE" Fill="#00FFFFFF" MouseLeftButtonDown="rectCorner_MouseLeftButtonDown" MouseLeftButtonUp="rectCorner_MouseLeftButtonUp" MouseMove="rectCorner_MouseMove" />
    </Grid>
</UserControl>