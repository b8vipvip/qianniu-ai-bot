<UserControl
	x:Class="Bot.AssistWindow.Widget.Robot.CtlRobot" 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Bot.AssistWindow.Widget.Robot"
	MinWidth="270">
    <Grid Margin="0">
        <Grid.RowDefinitions>
            <!-- 商品信息 -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="35"/>
            <!-- 聊天内容 -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>       

        <!-- 商品信息 -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"></RowDefinition>
            </Grid.RowDefinitions>
            <StackPanel x:Name="panelGoods">
                <ProgressBar x:Name="pgDownGoods"
					    Height="5"
					    Margin="2"
                        Visibility="Collapsed"
					    IsIndeterminate="True" />
            </StackPanel>
        </Grid>

        <Grid Background="DeepSkyBlue" Grid.Row="1" Margin="0 0 0 5">
            <Grid.RowDefinitions>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="auto" />
                <ColumnDefinition Width="auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Margin="5 0 0 0"  Text="正在接待" Foreground="#FFFFFFFF" VerticalAlignment="Center"></TextBlock>
            <TextBlock Margin="5 0 0 0" x:Name="txtBuyer" Text="..." Grid.Column="1"
                Foreground="Yellow" FontWeight="Bold" FontSize="13"
                VerticalAlignment="Center"></TextBlock>
            <CheckBox
                Name="cboxBotEnabled"
                Grid.Column="3"
                Margin="2 0 5 0"
                ToolTip="总开关。关闭后不调用AI、不自动发送，只保留插件窗口。"
                Foreground="#FFFFFFFF"
                VerticalAlignment="Center"
                Click="cboxBotEnabled_Click">启用Bot</CheckBox>
            <CheckBox
                Name="cboxAuto"
                Grid.Column="4"
                Margin="2 0 5 0"
                ToolTip="开启后AI答案会直接发送给顾客；关闭后只在右侧生成答案，不发送。"
                Foreground="#FFFFFFFF"
                VerticalAlignment="Center"
                Click="cboxAuto_Click">自动回复</CheckBox>
        </Grid>
        <!-- 聊天内容 -->
        <ScrollViewer x:Name="scvBody" Grid.Row="2" Margin="0">
            <StackPanel x:Name="stkDialog">
                <Grid
                    Name="grdShowConv"
                    Row="1"
                    Background="#FFFFFFFF"
                    Visibility="Collapsed">
                    <ProgressBar
				        Height="20"
				        Margin="20"
				        IsIndeterminate="True" />
                </Grid>
                <Grid Name="grdTipNoConv" Background="#FFFFFFFF" Height="200" Visibility="Collapsed">
                    <TextBlock  HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="20" Text="暂无聊天内容" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>