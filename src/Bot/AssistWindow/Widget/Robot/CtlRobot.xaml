<UserControl
    x:Class="Bot.AssistWindow.Widget.Robot.CtlRobot" 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:local="clr-namespace:Bot.AssistWindow.Widget.Robot"
    MinWidth="360">
    <UserControl.Resources>
        <SolidColorBrush x:Key="Bg" Color="#F7F9FC" />
        <SolidColorBrush x:Key="CardBg" Color="#FFFFFF" />
        <SolidColorBrush x:Key="Border" Color="#E6ECF2" />
        <SolidColorBrush x:Key="PrimaryBlue" Color="#2F80ED" />
        <SolidColorBrush x:Key="SoftBlue" Color="#EAF5FF" />
        <SolidColorBrush x:Key="TextMain" Color="#1F2937" />
        <SolidColorBrush x:Key="TextMuted" Color="#6B7280" />
        <SolidColorBrush x:Key="Success" Color="#27AE60" />
        <SolidColorBrush x:Key="Warn" Color="#F2994A" />
        <Style x:Key="StatsCard" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0 0 0 8"/>
        </Style>
        <Style x:Key="SmallLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="11"/>
        </Style>
        <Style x:Key="StatNumber" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMain}"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="StatusText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0 2 14 2"/>
        </Style>
    </UserControl.Resources>
    <Grid Background="{StaticResource Bg}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource CardBg}" BorderBrush="{StaticResource Border}" BorderThickness="0 0 0 1" Padding="9 5">
            <StackPanel>
                <DockPanel Margin="0" Visibility="Collapsed">
                    <TextBlock Text="状态" FontWeight="Bold" Foreground="{StaticResource TextMain}" />
                    <TextBlock x:Name="txtStatusSummary" Text="正在检测..." HorizontalAlignment="Right" Foreground="{StaticResource PrimaryBlue}" FontSize="11" />
                </DockPanel>
                <WrapPanel>
                    <TextBlock x:Name="txtConnectionStatus" Text="连接状态：正在检测" Style="{StaticResource StatusText}" />
                    <TextBlock x:Name="txtStatusApi" Text="API连接：未配置" Style="{StaticResource StatusText}" />
                </WrapPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource CardBg}" BorderBrush="{StaticResource Border}" BorderThickness="0 0 0 1" Padding="8 6" Visibility="Visible">
            <StackPanel x:Name="panelGoods">
                <ProgressBar x:Name="pgDownGoods" Height="4" Margin="0 0 0 6" Visibility="Collapsed" IsIndeterminate="True" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#00B8D9" CornerRadius="0" Margin="0 0 0 6" Padding="10 8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="正在接待" Foreground="#FFFFFFFF" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtBuyer" Text="..." Margin="8 0 0 0" Foreground="#FFF9D423" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="8 0">
                    <TextBlock Text="客服：" Foreground="#DFF7FF" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtSeller" Text="..." Foreground="#FFFFFFFF" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <Border Grid.Column="2" Background="#2EE59D" CornerRadius="10" Padding="8 2" VerticalAlignment="Center">
                    <TextBlock x:Name="txtRunStatus" Text="自动回复中" Foreground="#FFFFFFFF" FontSize="11" FontWeight="Bold"/>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="colDashboard" Width="0"/>
            </Grid.ColumnDefinitions>
            <ScrollViewer x:Name="scvBody" Grid.Column="0" Margin="0" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="stkDialog">
                    <Grid Name="grdShowConv" Background="#FFFFFFFF" Visibility="Collapsed">
                        <ProgressBar Height="20" Margin="20" IsIndeterminate="True" />
                    </Grid>
                    <Border Name="grdTipNoConv" Background="#FFFFFFFF" BorderBrush="{StaticResource Border}" BorderThickness="1" CornerRadius="8" Height="180" Margin="8" Visibility="Collapsed">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="暂无聊天内容" FontSize="18" Foreground="{StaticResource TextMuted}" HorizontalAlignment="Center"/>
                            <TextBlock Text="开启无障碍模式后，买家消息会显示在这里" FontSize="12" Foreground="#9CA3AF" Margin="0 8 0 0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <Border x:Name="gridDashboard" Grid.Column="1" Background="#F3F7FB" BorderBrush="{StaticResource Border}" BorderThickness="1 0 0 0" Padding="10" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="数据台" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextMain}" Margin="0 0 0 10"/>
                        <Border Style="{StaticResource StatsCard}">
                            <StackPanel>
                                <TextBlock Text="接待概览" FontWeight="Bold" Foreground="{StaticResource TextMain}" Margin="0 0 0 8"/>
                                <UniformGrid Columns="2">
                                    <StackPanel Margin="0 0 8 8"><TextBlock Text="总接待" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="txtTotalReception" Text="0" Style="{StaticResource StatNumber}"/></StackPanel>
                                    <StackPanel Margin="0 0 0 8"><TextBlock Text="今日接待" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="txtTodayReception" Text="0" Style="{StaticResource StatNumber}"/></StackPanel>
                                    <StackPanel Margin="0 0 8 0"><TextBlock Text="总自动回复" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="txtTotalAutoReply" Text="0" Style="{StaticResource StatNumber}"/></StackPanel>
                                    <StackPanel><TextBlock Text="今日自动回复" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="txtTodayAutoReply" Text="0" Style="{StaticResource StatNumber}"/></StackPanel>
                                </UniformGrid>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatsCard}">
                            <StackPanel>
                                <TextBlock Text="AI调用" FontWeight="Bold" Foreground="{StaticResource TextMain}" Margin="0 0 0 8"/>
                                <UniformGrid Columns="2">
                                    <StackPanel Margin="0 0 8 8"><TextBlock Text="总调用" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="txtTotalAiCall" Text="0" Style="{StaticResource StatNumber}"/></StackPanel>
                                    <StackPanel Margin="0 0 0 8"><TextBlock Text="今日调用" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="txtTodayAiCall" Text="0" Style="{StaticResource StatNumber}"/></StackPanel>
                                    <StackPanel Margin="0 0 8 0"><TextBlock Text="总Token" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="txtTotalTokens" Text="0" Style="{StaticResource StatNumber}"/></StackPanel>
                                    <StackPanel><TextBlock Text="今日Token" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="txtTodayTokens" Text="0" Style="{StaticResource StatNumber}"/></StackPanel>
                                </UniformGrid>
                                <TextBlock x:Name="txtAvgLatency" Text="平均耗时：0ms" Foreground="{StaticResource TextMuted}" FontSize="12" Margin="0 8 0 0"/>
                                <TextBlock x:Name="txtLastError" Text="" Foreground="#EB5757" FontSize="12" TextWrapping="Wrap" Margin="0 4 0 0"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatsCard}">
                            <StackPanel>
                                <TextBlock Text="各API接口消耗" FontWeight="Bold" Foreground="{StaticResource TextMain}" Margin="0 0 0 8"/>
                                <StackPanel x:Name="panelApiStats" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>