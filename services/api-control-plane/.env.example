# 公网域名，例如 api-console.example.com。域名需解析到 Ubuntu 服务器公网 IP。
CONTROL_PLANE_DOMAIN=api-console.example.com
PUBLIC_BASE_URL=https://api-console.example.com

# 管理员登录
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-long-random-password

# Cookie 与会话签名。至少 32 字节随机值。
APP_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=true

# 上游 ApiKey 与企业微信敏感字段的加密主密钥。必须长期固定并纳入备份。
# 生成命令：
# docker run --rm python:3.11-slim python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEY_ENCRYPTION_KEY=replace-with-fernet-key

DATA_DIR=/data
DATABASE_PATH=/data/api-control-plane.db

# 深度测试/管理任务可使用较长超时；真实Bot请求由下面的运行时路由预算单独限制，
# 避免一个失效模型长时间占用请求、导致备用模型还没轮到就被客户端取消。
REQUEST_TIMEOUT_SECONDS=300
RUNTIME_TOTAL_BUDGET_SECONDS=45
RUNTIME_ATTEMPT_TIMEOUT_SECONDS=6
RUNTIME_MAX_URLS_PER_ROUTE=1
# 流式请求在收到第一个真实文本片段前仍允许切换中转站/模型；开始输出后锁定该上游。
RUNTIME_STREAM_FIRST_EVENT_TIMEOUT_SECONDS=8
RUNTIME_STREAM_IDLE_TIMEOUT_SECONDS=35
SCHEDULER_POLL_SECONDS=60

# 企业微信应用消息与加密回调请登录控制面，在“企业微信”页面配置。
# CorpID、应用 Secret、AgentId、接收成员、回调 Token、EncodingAESKey
# 均使用 API_KEY_ENCRYPTION_KEY 加密保存在 SQLite，不从 .env 读取。
