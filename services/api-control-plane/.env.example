# 公网域名，例如 api-console.example.com。域名需解析到 Ubuntu 服务器公网 IP。
CONTROL_PLANE_DOMAIN=api-console.example.com
PUBLIC_BASE_URL=https://api-console.example.com

# 管理员登录
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-long-random-password

# Cookie 与会话签名。至少 32 字节随机值。
APP_SECRET=replace-with-a-long-random-secret
COOKIE_SECURE=true

# 上游 ApiKey 加密密钥。必须长期固定并纳入备份。
# 生成命令：
# docker run --rm python:3.11-slim python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
API_KEY_ENCRYPTION_KEY=replace-with-fernet-key

DATA_DIR=/data
DATABASE_PATH=/data/api-control-plane.db
REQUEST_TIMEOUT_SECONDS=300
SCHEDULER_POLL_SECONDS=60

# 企业微信自建应用消息。
# CorpID、应用 Secret、AgentId、接收成员 UserID 均来自企业微信管理后台。
# 多个 UserID 使用竖线分隔，例如 zhangsan|lisi。
WECOM_APP_ENABLED=false
WECOM_CORP_ID=wwxxxxxxxxxxxxxxxx
WECOM_APP_SECRET=replace-with-wecom-app-secret
WECOM_AGENT_ID=1000002
WECOM_TO_USERS=replace-with-member-userid

# 企业微信“接收消息”回调配置。
# 管理后台回调 URL：https://你的域名/api/wecom/callback
# Token 与 EncodingAESKey 必须和企业微信后台填写的一致。
WECOM_CALLBACK_TOKEN=replace-with-random-callback-token
WECOM_CALLBACK_AES_KEY=replace-with-43-character-encoding-aes-key

# 允许从企业微信/个人微信插件回复工单的成员 UserID。
# 留空时仅允许 WECOM_TO_USERS 中的成员。
WECOM_ALLOWED_REPLY_USERS=

# 工单有效时间，范围 1 到 168 小时。
WECOM_TICKET_HOURS=24
